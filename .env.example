# MarkItDown Web — copy to .env and edit

# --- HTTP ---
WEB_PORT=8000
APP_NAME=MarkItDown Web
BASE_URL=http://localhost:8000

# --- Security ---
# IMPORTANT: generate a real one in production: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SECRET_KEY=change-me-to-a-long-random-string

# --- Debug ---
DEBUG=false

# --- Uploads ---
MAX_UPLOAD_SIZE=104857600

# --- Bootstrap admin (created on first run only) ---
BOOTSTRAP_USER=admin
BOOTSTRAP_PASSWORD=admin
# After first start, change BOOTSTRAP_PASSWORD or remove these lines so the user isn't re-touched.

# --- Local auth (username/password) ---
LOCAL_AUTH_ENABLED=true

# --- OIDC / Authentik ---
# Set OIDC_ENABLED=true to enable. If both are enabled, the login page shows both options.
OIDC_ENABLED=false
# Issuer URL, no trailing slash. Examples:
#   Authentik: https://authentik.example.com/application/o/<app-slug>/
#   Keycloak:  https://kc.example.com/realms/<realm>
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
# When true, OIDC users are auto-provisioned on first login. When false, admin must pre-create them.
OIDC_AUTO_CREATE_USERS=true
